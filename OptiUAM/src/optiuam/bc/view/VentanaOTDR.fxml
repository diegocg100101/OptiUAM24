<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="optiuam.bc.controller.VentanaOTDRController">
   <children>
      <ImageView fitHeight="423.0" fitWidth="690.0" layoutY="-23.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/fondoOsciloscopio.png" />
         </image>
      </ImageView>
      <ComboBox fx:id="cboxConectarA" layoutX="506.0" layoutY="239.0" prefHeight="25.0" prefWidth="80.0" promptText="Select" />
      <Label layoutX="516.0" layoutY="216.0" prefHeight="0.0" prefWidth="60.0" text="Connect to: ">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <Button fx:id="btnCrear" layoutX="530.0" layoutY="277.0" mnemonicParsing="false" onAction="#crearOTDR" styleClass="btn" stylesheets="/Static/CSS/style.css" text="OK" />
      <LineChart fx:id="grafica" layoutY="-6.0" prefHeight="429.0" prefWidth="495.0">
         <xAxis>
            <NumberAxis prefWidth="681.0" side="BOTTOM" fx:id="x" />
         </xAxis>
         <yAxis>
            <NumberAxis fx:id="y" side="LEFT" />
         </yAxis>
      </LineChart>
   </children>
</AnchorPane>
