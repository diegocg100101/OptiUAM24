<AnchorPane id="AnchorPane" prefHeight="300.0" prefWidth="450.0" style="-fx-background-color: lightcyan;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="optiuam.bc.controller.VentanaPulsoController">
   <children>
      <ImageView fitHeight="306.0" fitWidth="450.0" pickOnBounds="true">
         <image>
            <Image url="@../../../images/FondoAzul.png" />
         </image>
      </ImageView>
      <Label alignment="CENTER" layoutY="21.0" prefHeight="17.0" prefWidth="450.0" text="Signal Configuration">
         <font>
            <Font name="Arial Black" size="18.0" />
         </font></Label>
      <Separator layoutY="48.0" prefHeight="5.0" prefWidth="450.0" />
      <ImageView fitHeight="60.0" fitWidth="438.0" layoutX="6.0" layoutY="63.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/Funcion%20sennal.png" />
         </image>
         <effect>
            <Lighting>
               <bumpInput>
                  <Shadow />
               </bumpInput>
               <light>
                  <Light.Distant azimuth="229.19" color="#e9eeed" elevation="103.6" />
               </light>
            </Lighting>
         </effect>
      </ImageView>
      <Label layoutX="129.0" layoutY="113.0" text="(Red = Envelope, Blue = Chirp, Black = Carrier)">
