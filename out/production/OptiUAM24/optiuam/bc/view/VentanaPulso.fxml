      <Label layoutX="245.0" layoutY="170.0" text="T_0: Spectral width (nm)." />
      <Label layoutX="30.0" layoutY="191.0" text="C: Chirp." />
      <Label layoutX="245.0" layoutY="191.0" text="j: Imaginary unit." />
      <Label layoutX="30.0" layoutY="212.0" text="ω_0: Angular frequency." />
      <Label layoutX="245.0" layoutY="212.0" text="t: Time (s)." />
      <Label layoutX="30.0" layoutY="233.0" text="m: Pulse type (Gaussian or supergaussian)." />
      <Button fx:id="btnOk" layoutX="377.0" layoutY="228.0" mnemonicParsing="false" onAction="#cerrarVentana" text="Ok" />
   </children>
   <effect>
      <InnerShadow />
   </effect>
</AnchorPane>
